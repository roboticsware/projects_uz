# Turso Database Configuration
TURSO_DATABASE_URL="libsql://your-db-name.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# Nuxt Auth Utils (Google OAuth)
NUXT_OAUTH_GOOGLE_CLIENT_ID="your-google-client-id"
NUXT_OAUTH_GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Nuxt Auth Session Password (must be at least 32 characters)
NUXT_SESSION_PASSWORD="replace-this-with-a-random-32-character-long-string"

# Cloudflare R2 Image Storage
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
# Get from: R2 → Overview → Account ID in URL
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_BUCKET_NAME="your-bucket-name"
# Get from: R2 → Bucket → Settings → Public Access URL
R2_PUBLIC_URL="https://pub-xxxx.r2.dev"
